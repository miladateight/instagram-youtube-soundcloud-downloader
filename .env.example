BOT_NAME=DownloaderBot
BOT_TOKEN=123456789:replace-me
ADMIN_ID=123456789

# Keep false if this is a private test bot.
ALLOW_ALL_USERS=false

# Forced channel subscription is managed inside Telegram by the admin:
# /forcejoin_on @your_channel
# /forcejoin_off

# Telegram upload limits depend on the Bot API mode you use.
MAX_UPLOAD_MB=49

# Protect the server from huge playlist/profile downloads.
PLAYLIST_LIMIT=20
CONCURRENT_DOWNLOADS=1

DOWNLOAD_DIR=downloads
DATA_DIR=data
LOG_DIR=logs

# Optional. Use a Netscape cookies.txt exported from your browser if Instagram
# or YouTube asks for login/age verification.
COOKIES_FILE=
