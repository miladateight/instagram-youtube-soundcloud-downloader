BOT_NAME=DownloaderBot
BOT_TOKEN=123456789:replace-me
ADMIN_ID=123456789

# Initial default only. The admin can later change public access inside Telegram:
# /public_on
# /public_off
ALLOW_ALL_USERS=false

# Forced channel subscription is managed inside Telegram by the admin:
# /forcejoin_on @your_channel
# /forcejoin_off

# 0 means the bot will not block files by size. Telegram Bot API can still reject
# files that are above the real upload limit of your Bot API mode.
MAX_UPLOAD_MB=0

# Protect the server from huge playlist/profile downloads.
PLAYLIST_LIMIT=20
CONCURRENT_DOWNLOADS=100

DOWNLOAD_DIR=downloads
DATA_DIR=data
LOG_DIR=logs

# Optional. Use a Netscape cookies.txt exported from your browser if Instagram
# or YouTube asks for login/age verification.
COOKIES_FILE=
